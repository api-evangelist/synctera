    "CREDIT_NOT_ACCEPTED_BY_CUSTOMER",
    "CREDIT_ACCEPTED_BY_CUSTOMER"
  ],
  "type": "string",
  "x-enumDescriptions": [
    {
      "APPLICATION_SUBMITTED": "Credit application has been submitted"
