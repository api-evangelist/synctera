{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/balance_inquiry_request_model",
  "title": "balance_inquiry_request_model",
  "properties": {
    "account_type": {
      "enum": [
        "checking",
        "savings",
        "credit"
      ],
      "type": "string"
    },
    "card_acceptor": {
      "$ref": "#/components/schemas/card_acceptor_model"
    },
    "card_id": {
      "format": "uuid",
      "type": "string"
    },
    "mid": {
      "maxLength": 50,
      "minLength": 1,
      "type": "string"
    },
    "network_fees": {
      "items": {
        "$ref": "#/components/schemas/network_fee_model"
      },
      "type": "array"
    },
    "pin": {
      "maxLength": 15,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "account_type",
    "card_acceptor",
    "card_id",
    "mid"
  ],
  "type": "object"
}