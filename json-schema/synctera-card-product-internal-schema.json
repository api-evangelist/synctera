          "type": "string"
        },
        "partner_id": {
          "description": "Partner ID",
          "type": "integer"
        }
      },
      "required": [
        "bank_id",
        "partner_id",
        "funding_source_id",
        "bin_id",
        "account_range_id",
        "auto_allocate_range"
      ],
      "type": "object"
    }
  ],
  "description": "Card Product Internal"
}